# One of the following auth setups is required:
#
# 1. API key + TOTP secret (best for VPS auto-refresh from a whitelisted static IP)
# 2. API key + API secret
# 3. A manually generated access token
#
# Whitelist the trading server's public static IPv4 with Groww.
# Example VPS IP used by this stack: 89.167.33.51

GROWW_API_KEY=replace_me

# Option A: API key + TOTP secret
# GROWW_TOTP_SECRET=replace_me

# Option B: API key + API secret
# GROWW_API_SECRET=replace_me

# Optional one-shot override if you already minted a token manually.
# GROWW_ACCESS_TOKEN=replace_me
